    "policy_contact_description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte nutze das Kontaktformular auf unserer offiziellen Website.\nKopiere die URL und füge sie in deinen Browser ein."
          }
        },
        "en": {
          "stringUnit": {
