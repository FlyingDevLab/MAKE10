    "janken_how_to_play_body": {
      "comment": "A description of how to play janken.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Befehl erscheint — SIEGEN oder VERLIEREN!\nZeige so schnell wie möglich die passende Hand!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A command appears — WIN or LOSE!\nShow the matching hand as fast as you can!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Aparece un comando — GANAR o PERDER!\n¡Muestra la mano correcta lo más rápido posible!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une commande apparaît — GAGNER ou PERDRE !\nMontre la bonne main le plus vite possible !"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक कमांड आता है — जीतो या हारो!\nजितनी जल्दी हो सके सही हाथ दिखाओ!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebuah perintah muncul — MENANG atau KALAH!\nTunjukkan tangan yang sesuai secepat mungkin!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Appare un comando — VINCI o PERDI!\nMostra la mossa giusta più velocemente che puoi!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "指令が出るよ！\n「かって！」か「まけて！」に合う手をすばやく出そう！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "명령이 나타납니다 — 이겨라! 또는 져라!\n최대한 빨리 맞는 손을 내세요!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er verschijnt een opdracht — WINNEN of VERLIEZEN!\nToon zo snel mogelijk de juiste hand!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um comando aparece — GANHAR ou PERDER!\nMostre a mão certa o mais rápido que puder!"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำสั่งปรากฏขึ้น — ชนะ หรือ แพ้!\nแสดงมือที่ถูกต้องให้เร็วที่สุด!"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Một lệnh xuất hiện — THẮNG hoặc THUA!\nĐưa ra tay phù hợp nhanh nhất có thể!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "指令出现——赢！或 输！\n尽快出对应的手势！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "指令出現——贏！或 輸！\n盡快出對應的手勢！"
          }
        }
      }
    },
