          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il modulo di contatto sul nostro sito ufficiale.\nCopia l'URL e incollalo nel tuo browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "お問い合わせは公式サイトのフォームをご利用ください。\nURLをコピーして、ブラウザに貼り付けてアクセスできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공식 사이트의 문의 양식을 이용해 주세요.\nURL을 복사하여 브라우저에 붙여넣으세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
