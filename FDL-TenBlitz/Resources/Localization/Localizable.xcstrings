    "reset_confirm_progress_body": {
      "comment": "Body text of the Reset Progress confirmation alert.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle freigeschalteten Modi werden zurückgesetzt. Bist du sicher?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All unlocked modes will be reset. Are you sure?"
