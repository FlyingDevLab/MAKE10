    "reset_confirm_high_score_body": {
      "comment": "Body text of the Reset High Score confirmation alert.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein bestes Ergebnis wird auf 0 zurückgesetzt. Bist du sicher?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your high score will be reset to 0. Are you sure?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu mejor puntuación volverá a 0. ¿Estás seguro?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre meilleur score sera remis à 0. Êtes-vous sûr ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका हाई स्कोर 0 हो जाएगा। क्या आप sure हैं?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Skor terbaik akan direset ke 0. Yakin?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo punteggio migliore verrà azzerato. Sei sicuro?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイスコアが 0 にもどります。よろしいですか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최고 기록이 0으로 초기화됩니다. 괜찮으세요?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je beste score wordt gereset naar 0. Weet je het zeker?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua melhor pontuação será redefinida para 0. Tem certeza?"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คะแนนสูงสุดของคุณจะถูกรีเซ็ตเป็น 0 แน่ใจหรือไม่?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Điểm cao nhất của bạn sẽ được đặt lại về 0. Bạn có chắc không?"
          }
        },
        "zh-Hans": {
